{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "projects": {
    "assignment-app": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {

        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "src/main.ts",
            "index": "src/index.html",
            "tsConfig": "tsconfig.app.json",

            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],

            "styles": [
              "src/styles.css"
            ],

            "scripts": []
          },

          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all"
            },

            "development": {
              "optimization": false,
              "sourceMap": true,
              "extractLicenses": false
            }
          },

          "defaultConfiguration": "development"
        },

        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "development": {
              "buildTarget": "assignment-app:build:development"
            },

            "production": {
              "buildTarget": "assignment-app:build:production"
            }
          },

          "defaultConfiguration": "development"
        }

      }
    }
  },

  "cli": {
    "analytics": false
  }
}